{
  "name": "@yanxulang/docs",
  "version": "1.1.20",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build && npm run redirects:generate && npm run site:check",
    "dev": "next dev",
    "start": "serve out",
    "check": "npm run syntax:check && npm run search:test && npm run content:check && npm run types:check && npm run lint",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "content:check": "node scripts/check-content.mjs",
    "links:check": "node scripts/check-external-links.mjs",
    "syntax:check": "node scripts/check-syntax.mjs",
    "syntax:upstream": "node scripts/check-syntax.mjs --upstream",
    "search:test": "node --experimental-strip-types --test tests/search-tokenizer.test.ts",
    "redirects:generate": "node scripts/generate-redirects.mjs",
    "site:check": "node scripts/check-site.mjs out"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.4",
    "fumadocs-mdx": "15.1.1",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.4",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@shikijs/types": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.17",
    "serve": "^14.2.6",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
